# ===================================
# Sentinel AI Platform Configuration
# ===================================

# Application
APP_NAME=Sentinel AI
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# ===== AWS Configuration =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
KNOWLEDGE_BASE_ID=your_kb_id

# DynamoDB Tables
DYNAMODB_TABLE_CAMPAIGNS=CampaignSessions
DYNAMODB_TABLE_AUDIT=AuditLogs

# S3
S3_BUCKET_REPORTS=sentinel-ai-artifacts

# ===== MongoDB Configuration =====
MONGO_URL=mongodb://localhost:27017
MONGO_DB=sentinel_ai

# ===== n8n Workflow Automation =====
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key-here
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ===== Local LLM (Ollama) =====
LLM_PROVIDER=ollama
LLM_MODEL=llama2
LLM_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ===== Agent Configuration =====
AGENT_TIMEOUT=300
AGENT_MAX_RETRIES=3
AGENT_CONCURRENT_LIMIT=5

# Offensive Agent Settings
RECON_ENABLED=True
SCANNER_ENABLED=True
VULN_ENABLED=True

# Defensive Agent Settings
THREAT_DETECTION_ENABLED=True
HARDENING_ENABLED=True

# Scanning Limits
MAX_SCAN_TARGETS=100
SCAN_RATE_LIMIT=10
SCAN_TIMEOUT=600

# ===== Security =====
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here
ADMIN_JWT_SECRET=your-admin-jwt-secret-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Frontend WebSocket =====
FRONTEND_WS_URL=ws://localhost:3000
ADMIN_WS_URL=ws://localhost:3001

# ===== Optional API Keys =====
SHODAN_API_KEY=your-shodan-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ===== Agent Enhancements =====
# Multi-LLM Support (optional — leave blank to use Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Knowledge Store (ChromaDB — auto-created locally)
CHROMADB_PATH=./data/chromadb
CHROMADB_COLLECTION=security_findings

# Threat Intelligence
THREAT_INTEL_CACHE_TTL_HOURS=24
NVD_API_KEY=  # Optional — get free key from https://nvd.nist.gov/developers/request-an-api-key

# Agent Mode: 'default' (AgentExecutor) or 'langgraph' (multi-step reasoning)
AGENT_MODE=default

# Kill Switch: set to 'true' to disable all offensive agent operations
AGENT_KILL_SWITCH=false
