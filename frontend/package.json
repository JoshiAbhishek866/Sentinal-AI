    "clear-cache": "node clear-cache.js",
    "test": "vitest"
  },
  "dependencies": {
    "@heroicons/vue": "^2.0.18",
    "@vueuse/head": "^2.0.0",
    "axios": "^1.6.2",
    "chart.js": "^4.5.1",
    "gsap": "^3.14.2",
    "pinia": "^2.1.7",
    "three": "^0.183.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.10",
    "vitest": "^4.0.16"
