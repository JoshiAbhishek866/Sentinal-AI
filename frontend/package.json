{
  "name": "Sentinel AI-frontend",
  "version": "1.0.0",
  "description": "Sentinel AI Cybersecurity Platform - Vue.js 3 + Vite",
  "type": "module",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
